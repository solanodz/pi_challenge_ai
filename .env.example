OPENAI_API_KEY=your_openai_api_key
CORPUS_PATH=docs/documento.docx
CHROMA_COLLECTION=corpus
CHROMA_API_KEY=your_chroma_api_key
CHROMA_TENANT=your_chroma_tenant_id
CHROMA_DATABASE=pi_challenge_AI
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# Max L2 distance for a retrieval to be trusted (calibrate after ingest)
# L2 distance; calibrate with debug.retrieval_distance (Alex ~1.34, off-topic ~1.76+)
RETRIEVAL_DISTANCE_MAX=1.77
# Docker only: set to true to skip ingest on container start
SKIP_INGEST=false
